# =================================================================
# DEVLEDS SMART INVOICE GENERATOR — ENVIRONMENT TEMPLATE
# Copy this file to '.env' and fill in your custom configurations.
# =================================================================

# 1. DATABASE CONFIGURATION
# MongoDB Connection String (Atlas or Local instance)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DB_NAME=smart_invoice

# 2. GOOGLE GEMINI AI CONFIGURATION
# Your Gemini API Key from Google AI Studio (needed for AI Style Cloning)
GEMINI_API_KEY=your_gemini_api_key_here

# 3. AUTHENTICATION & SECURITY
# A secure 256-bit random string for signing JWT tokens
# Generate one using: openssl rand -hex 32
SECRET_KEY=generate_a_secure_random_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Default Admin Credentials for Dashboard Access
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_default_password

# 4. EMAIL SMTP SERVER CONFIGURATION (For Automated OTP Delivery)
# Fill this with your email provider settings (e.g. Gmail App Password)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_sender_email@gmail.com
MAIL_PASSWORD=your_16_digit_app_password
MAIL_FROM_NAME="Devleds Support"

# Personal Admin and Test Accounts (For setup scripts)
ADMIN_EMAIL=your_personal_admin@example.com
USER_EMAIL=your_personal_user@example.com
